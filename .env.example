# ─────────────────────────────────────────────
# FUNNEL STUDIO — Variables d'environnement
# ─────────────────────────────────────────────
# RÈGLE : ne jamais écrire de texte après "="
# Seuls les vrais secrets vont ici.
# ─────────────────────────────────────────────

# GitHub
# Format GITHUB_REPO : owner/repo  (ex: moncompte/ma-page)
# GITHUB_TOKEN est optionnel si tu utilises Lovable via OAuth GitHub
GITHUB_TOKEN=
GITHUB_REPO=

# Vercel
# Seul VERCEL_TOKEN est requis — rempli manuellement
# VERCEL_PROJECT_ID et VERCEL_ORG_ID sont auto-générés — laisser vides
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=

# Cloudflare Pages
# CLOUDFLARE_API_TOKEN : créer sur dash.cloudflare.com/profile/api-tokens
# CLOUDFLARE_ACCOUNT_ID : visible dans le dashboard Cloudflare (coin droit)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Lovable
# Aucune clé API requise — connexion via OAuth GitHub uniquement
# Ne pas ajouter de variable LOVABLE_API_KEY
